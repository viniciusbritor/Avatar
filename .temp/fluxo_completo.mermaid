%% ─── Brasil AI Avatar — Fluxo Industrial Completo v3.2.1 ───
%% Inclui o Sentinel no HOST corrigido (2026-05-05)

flowchart TD
    %% ═══════════════════════════════════════════════════════
    %% FASE 0: ENTRADA DO USUÁRIO
    %% ═══════════════════════════════════════════════════════
    CLIENT["🧑 Usuário
    POST /produce
    X-API-Key: brasilai-avatar-2026
    {'text': 'Olá, eu sou a Cris...'}"]
    
    AUTH{"🔐 Valida X-API-Key
    contra Secret Manager
    (fallback: env var)"}
    REJECT["❌ 401 Unauthorized"]
    SHORT["❌ 400 Texto < 5 chars"]

    CLIENT --> AUTH
    AUTH -- "inválida" --> REJECT
    AUTH -- "válida" --> TXT{"📝 Texto ≥ 5 chars?"}
    TXT -- "não" --> SHORT
    TXT -- "sim" --> PHASE1

    %% ═══════════════════════════════════════════════════════
    %% FASE 1: GERAÇÃO DE ÁUDIO (ElevenLabs)
    %% ═══════════════════════════════════════════════════════
    subgraph PHASE1["🎙️ FASE 1: TEXT-TO-SPEECH"]
        TTS["POST api.elevenlabs.io/v1/text-to-speech
        Voice: XrExE9yKIg1WjnnlVkGX (Matilda/Sarah PT-BR)
        Model: eleven_multilingual_v2
        Stability: 0.50 | Similarity: 0.80"]
        AUDIO_FILE["audio_{uuid}.mp3
        salvo em temp/"]
    end

    TXT --> TTS
    TTS --> AUDIO_FILE

    %% ═══════════════════════════════════════════════════════
    %% FASE 2: UPLOAD + FIRESTORE
    %% ═══════════════════════════════════════════════════════
    subgraph PHASE2["☁️ FASE 2: UPLOAD + PERSISTÊNCIA"]
        UPLOAD["⬆️ Upload para GCS
        gs://brasil-ai-avatars-vault/temp/audio_{uuid}.mp3"]
        FIRESTORE_WRITE["📝 Firestore: avatar_jobs/{job_id}
        status: 'queued'
        text, audio_url, webhook_url
        created_at: BRT timestamp"]
    end

    AUDIO_FILE --> UPLOAD
    AUDIO_FILE --> FIRESTORE_WRITE

    %% ═══════════════════════════════════════════════════════
    %% FASE 3: CAÇA POR GPU (Orquestrador)
    %% ═══════════════════════════════════════════════════════
    subgraph PHASE3["🔍 FASE 3: CAÇA POR GPU L4"]
        ORCH["🤖 AgenteLanaOrchestrator
        detecta plataforma:
        Linux → CloudLanaEngine
        Windows → LanaIndustrialEngine"]

        SEARCH_EXISTING{"🔎 Busca VMs existentes
        gcloud compute instances list
        filter: name~lana-engine-
        AND status=RUNNING"}

        FOUND{"Encontrou
        VM ativa?"}

        CHECK_HEALTH{"❤️ Health check
        GET :8080/health"}

        CHECK_BUSY{"🔒 Está ocupada?
        IS_BUSY flag?"}

        REUSE["♻️ REUSA VM existente
        heartbeat_thread ativo
        touch /workspace/heartbeat a cada 60s"]

        WAKE_TRY{"💤 Tenta acordar
        VMs TERMINATED?
        gcloud instances start"}

        WAKE_OK{"Acordou
        com sucesso?"}

        PURGE_WAKE["🗑️ Purga VM zumbi
        delete instance + disk"]

        %% ─── CRIAÇÃO DE NOVA GPU ───
        ZONE_LOOP["🔄 Loop 13 zonas globais:
        us-east1-c → us-west4-a → us-east1-d
        → us-east4-a → us-west1-a → us-central1-a
        → us-east5-a → us-south1-a → europe-west4-a
        → europe-west1-b → europe-west6-b
        → asia-east1-a → northamerica-northeast1-b"]

        TRY_ZONE{"Tenta zona atual
        Retry 2x por zona
        (quota exhaustion)"}

        ZONE_FAIL{"❌ Zona falhou
        (Quota cheia, stockout,
        ZONE_RESOURCE_POOL_EXHAUSTED)"}

        NEXT_ZONE{"Próxima zona
        disponível?"}

        CREATE_VM["✅ gcloud compute instances create
        Machine: g2-standard-12 (L4 24GB)
        Image: common-cu129-ubuntu-2204-nvidia-580
        Disk: 150GB boot
        Provisioning: STANDARD
        Maintenance: TERMINATE
        Scopes: cloud-platform
        ─────────────────
        Metadata:
        startup-script = /app/infra/startup_arch4.sh"]

        RETRY3{"3 tentativas
        globais
        esgotadas?"}

        FAIL_ALL["💀 GPU não encontrada
        após 3 tentativas
        Job fica 'queued'
        Aguarda próximo polling"]
    end

    FIRESTORE_WRITE --> ORCH
    ORCH --> SEARCH_EXISTING

    SEARCH_EXISTING --> FOUND
    FOUND -- "sim" --> CHECK_HEALTH
    CHECK_HEALTH -- "ok" --> CHECK_BUSY
    CHECK_HEALTH -- "falhou" --> PURGE_WAKE
    CHECK_BUSY -- "livre" --> REUSE
    CHECK_BUSY -- "ocupada (429)" --> ZONE_LOOP

    FOUND -- "não" --> WAKE_TRY
    WAKE_TRY --> WAKE_OK
    WAKE_OK -- "sim" --> CHECK_HEALTH
    WAKE_OK -- "não" --> PURGE_WAKE
    PURGE_WAKE --> ZONE_LOOP

    ZONE_LOOP --> TRY_ZONE
    TRY_ZONE -- "ok" --> CREATE_VM
    TRY_ZONE -- "falhou" --> ZONE_FAIL
    ZONE_FAIL --> NEXT_ZONE
    NEXT_ZONE -- "sim" --> TRY_ZONE
    NEXT_ZONE -- "não" --> RETRY3
    RETRY3 -- "sim" --> ZONE_LOOP
    RETRY3 -- "não" --> FAIL_ALL

    %% ═══════════════════════════════════════════════════════
    %% FASE 4: BOOT DA VM (startup_arch4.sh v5)
    %% ═══════════════════════════════════════════════════════
    subgraph PHASE4["⚡ FASE 4: BOOT DA GPU (startup_arch4.sh v5)"]
        DEADMAN["💣 Dead Man's Switch
        echo 'shutdown -P +90' | at now
        Proteção absoluta: 90 min máx"]

        DOCKER_INSTALL["🐳 Instala Docker + NVIDIA Toolkit
        (se não existirem)"]

        GCSFUSE["📦 Monta GCS Fuse
        gcsfuse --only-dir checkpoints
        lana-weights-universal → /mnt/weights
        Modelos carregados via streaming
        Zero download time"]

        WORKSPACE["📂 Prepara /workspace
        chmod 777"]

        DOCKER_AUTH["🔑 gcloud auth configure-docker
        Artifact Registry: us-east1-docker.pkg.dev
        Retry: 10x com sleep 6s"]

        PULL_IMAGE["⬇️ docker pull avatar-l4:v2.10-golden
        ~15GB, retry 5x
        Contém: LatentSync, GFPGAN, PyTorch,
        InsightFace, Whisper, CUDA 12.1"]

        SYNC_ASSETS["📥 Sync assets + checkpoints
        gsutil cp assets/*.mp4 → /workspace/latentsync/assets/
        ln -sfn /mnt/weights → /workspace/latentsync/checkpoints"]

        RUN_CONTAINER["🚀 docker run -d --name lana-engine
        --gpus all --network host
        -v /workspace:/workspace
        -v /mnt/weights:/mnt/weights
        python3 /workspace/src/industrial_main.py"]

        CONTAINER_ALIVE{"✅ Container
        está rodando?"}

        SENTINEL_HOST["🛡️ lana-sentinel.service (HOST)
        systemd unit fora do container
        Checa a cada 30s:
        • docker ps (container vivo?)
        • nvidia-smi (GPU util?)
        • /workspace/heartbeat
        ─────────────────
        Container morto? → shutdown 10 min
        GPU idle?        → shutdown 30 min"]

        CONTAINER_DIED["💀 Container MORREU
        (OOM, crash, bug)
        ─────────────────
        Antes: GPU ficava ligada 90 min
        Agora: Sentinel detecta em 30s
        e desliga em 10 min"]
    end

    CREATE_VM --> PHASE4
    DEADMAN --> DOCKER_INSTALL --> GCSFUSE --> WORKSPACE --> DOCKER_AUTH --> PULL_IMAGE --> SYNC_ASSETS --> RUN_CONTAINER
    RUN_CONTAINER --> CONTAINER_ALIVE
    CONTAINER_ALIVE -- "sim" --> SENTINEL_HOST
    CONTAINER_ALIVE -- "não" --> CONTAINER_DIED
    CONTAINER_DIED --> SENTINEL_HOST

    %% ═══════════════════════════════════════════════════════
    %% FASE 5: POLLING + RENDER
    %% ═══════════════════════════════════════════════════════
    subgraph PHASE5["🎬 FASE 5: POLLING + RENDERIZAÇÃO"]
        POLL["🔄 poll_pending_jobs() thread
        Firestore: avatar_jobs
        WHERE status == 'queued'
        Poll a cada 10s"]

        HAS_JOB{"📋 Job
        pendente?"}

        IDLE_COOLDOWN["⏱️ Idle detection:
        MAX_IDLE: 90 ciclos (15 min)
        COOLDOWN: 30 ciclos (5 min)
        Se idle → sudo shutdown -h now"]

        MARK_RUNNING["📝 Firestore update:
        status = 'running'"]

        DL_AUDIO["⬇️ Download audio do GCS
        gs://brasil-ai-avatars-vault/temp/audio_{job_id}.mp3"]

        SELECT_TEMPLATE["🎞️ Seleciona template MP4
        /workspace/latentsync/assets/
        lana_intro.mp4 / lana_comentario.mp4 / lana_base_25fps.mp4"]

        WHISPER["🧠 Whisper small.pt (244M params)
        audio2feat() → encoder embeddings
        feature2chunks() → alinha 25 FPS
        768-dim audio embeddings
        ─────────────────
        Se cross_attention_dim=384:
        nn.Linear(768→384) projection"]

        FACE_DETECT["👁️ InsightFace 106 landmarks
        affine_transform_video()
        Recorta + alinha rosto
        Template canônico 256/512px"]

        MASK["🎭 Mouth mask (CPU)
        cv2.erode(MORPH_ELLIPSE 3x3)
        shape: (3, h, w)
        NUNCA mover para CUDA"]

        VAE["🔮 VAE Encode
        stabilityai/sd-vae-ft-mse
        Imagens → latent space
        Concat: [noise, mask, masked_img, ref] × 13 canais"]

        UNET["🏗️ 3D UNet Denoising (20 steps)
        guidance_scale: 2.5
        Cross-attention: audio embeddings
        DeepCache ativado (economia VRAM)
        Classifier-free guidance:
        noise_pred = uncond + 2.5×(audio - uncond)"]

        VAE_DECODE["🔮 VAE Decode
        Latents → pixel space
        paste_surrounding_pixels_back()
        Substitui APENAS boca (mask=0)"]

        GFPGAN["✨ GFPGAN v1.4 Face Restoration
        face_enhancer.enhance() por frame
        paste_back=True (fusão automática)
        clear CUDA cache a cada 30 frames
        Roda na CPU (BGR OpenCV)"]

        FFMPEG["🎥 ffmpeg mux
        H.264 (crf 18) + AAC audio
        -map 0:v:0 -map 1:a:0 -shortest"]

        UPLOAD_VIDEO["⬆️ Upload vídeo final
        gs://brasil-ai-avatars-vault/outputs/
        avatar_{timestamp_BRT}.mp4"]

        WEBHOOK["📡 notify_webhook()
        POST /webhook/render-complete
        Headers: X-API-Key
        Body: {job_id, status, video_path}
        Retry: 5x com 5s entre tentativas"]

        TOUCH_IDLE["💤 touch /workspace/idle_now
        Hint para o Sentinel:
        'terminei, pode desligar em 5 min'"]
    end

    SENTINEL_HOST --> POLL
    POLL --> HAS_JOB
    HAS_JOB -- "sim" --> MARK_RUNNING --> DL_AUDIO --> SELECT_TEMPLATE --> WHISPER --> FACE_DETECT --> MASK --> VAE --> UNET --> VAE_DECODE --> GFPGAN --> FFMPEG --> UPLOAD_VIDEO --> WEBHOOK --> TOUCH_IDLE
    HAS_JOB -- "não" --> IDLE_COOLDOWN
    TOUCH_IDLE --> POLL

    %% ═══════════════════════════════════════════════════════
    %% FASE 6: WEBHOOK + ENTREGA
    %% ═══════════════════════════════════════════════════════
    subgraph PHASE6["📦 FASE 6: WEBHOOK + ENTREGA"]
        API_RECEIVE["📥 API recebe webhook
        POST /webhook/render-complete
        Valida X-API-Key"]

        UPDATE_FIRESTORE["📝 Firestore update:
        status = 'completed'
        video_path = gs://.../avatar_{timestamp}.mp4
        completed_at = BRT timestamp
        message = 'Video concluido pela GPU.'"]

        SYNC_BRIDGE["🔄 sync_bridge.py (local)
        Polling Firestore a cada 5s
        WHERE status='completed'
        AND downloaded_at IS NULL"]

        DOWNLOAD_LOCAL["⬇️ Download GCS → local
        Salva em sucesso/
        avatar_{timestamp}.mp4"]

        MARK_DOWNLOADED["✅ downloaded_at = now()
        Job arquivado no Firestore"]
    end

    WEBHOOK --> API_RECEIVE --> UPDATE_FIRESTORE
    UPDATE_FIRESTORE -.-> SYNC_BRIDGE
    SYNC_BRIDGE --> DOWNLOAD_LOCAL --> MARK_DOWNLOADED

    %% ═══════════════════════════════════════════════════════
    %% FASE 7: PURGA (Zero-Waste)
    %% ═══════════════════════════════════════════════════════
    subgraph PHASE7["🗑️ FASE 7: PURGA ZERO-WASTE"]
        SHUTDOWN_LAYERS["🛡️ 3 camadas de shutdown:
        ─────────────────
        Layer 1 (10 min): Sentinel HOST
        detecta container morto
        ─────────────────
        Layer 2 (30 min): Sentinel HOST
        detecta GPU idle + sem heartbeat
        ─────────────────
        Layer 3 (90 min): Dead Man's Switch
        at command: shutdown -P +90
        Proteção absoluta"]

        POWEROFF["🔌 sudo poweroff
        GPU desligada
        Custo = ZERO"]

        ORCH_PURGE["🗑️ Orquestrador detecta VM parada
        _purge_zone(): delete instance + disk
        --delete-disks=all --quiet"]
    end

    TOUCH_IDLE --> SHUTDOWN_LAYERS
    IDLE_COOLDOWN --> SHUTDOWN_LAYERS
    CONTAINER_DIED --> SHUTDOWN_LAYERS
    SHUTDOWN_LAYERS --> POWEROFF
    POWEROFF -.-> ORCH_PURGE

    %% ═══════════════════════════════════════════════════════
    %% STATUS CODES
    %% ═══════════════════════════════════════════════════════
    subgraph LEGEND["📊 LEGENDA"]
        L1["🟢 Linha contínua: fluxo síncrono"]
        L2["🔵 Linha pontilhada: fluxo assíncrono (polling/eventos)"]
        L3["🔴 Vermelho: falha / erro"]
    end

    %% ═══════════════════════════════════════════════════════
    %% TEMPO TOTAL ESTIMADO
    %% ═══════════════════════════════════════════════════════
    subgraph TIMING["⏱️ TEMPOS TÍPICOS"]
        T1["Fase 1 (TTS):       ~3s"]
        T2["Fase 2 (Upload):    ~2s"]
        T3["Fase 3 (Caça GPU):  ~30-90s (cria) | ~5s (reusa)"]
        T4["Fase 4 (Boot):      ~4-7 min (inclui pull 15GB)"]
        T5["Fase 5 (Render):    ~40-50s por frame de áudio"]
        T6["Fase 6 (Entrega):   ~5-10s webhook + download"]
        T7["Fase 7 (Purga):     ~5-10 min pós-job | imediato se container morto"]
    end
