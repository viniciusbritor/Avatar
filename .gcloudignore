# .gcloudignore — Brasil AI Avatar API (Build Context)
# Exclui arquivos desnecessários do upload para Cloud Build.
# Apenas o que a API precisa é enviado.

# Ignorar tudo por padrão
*

# Liberar: código da API
!api/
!api/**

# Liberar: código do engine original (src/)
!src/
!src/**

# Liberar: submodule LatentSync (bytedance/LatentSync)
!latentsync/
!latentsync/**

# Liberar: startup script para provisionar a GPU VM
!infra/
!infra/startup_arch4.sh
!infra/Dockerfile.avatar-l4-v2.10
!infra/requirements-l4.txt

# Liberar: config do build
!cloudbuild.yaml
!cloudbuild-*.yaml
!requirements.txt
!.gitmodules

# Excluir cache Python e outputs
__pycache__/
*.pyc
outputs/
.git/
