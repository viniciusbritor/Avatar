# ─── Brasil AI Avatar L4 — Dockerfile v2.10 (Layers Otimizadas) ──────────
# Arquitetura de layers independentes para cache eficiente:
#   1. apt (sistema)            — rebuild só se mudar ffmpeg/python
#   2. PyTorch CUDA 12.1        — rebuild só se mudar versão CUDA/torch
#   3. ML Core                  — rebuild só se mudar diffusers/transformers
#   4. LatentSync Deps          — rebuild só se adicionar lib nova
#   5. DeepCache (git)          — rebuild só se mudar ref do repo
#   6. API Server deps          — rebuild só se mudar fastapi/uvicorn
#
# Ganho: mudar 1 lib nova → 2-3 minutos (layer 4+5+6)
#        mudar PyTorch → 15 minutos (layer 2 a 6)
#
# NOTA: Código Python (src/ + latentsync/) NÃO vai na imagem.
#       Obtido via git clone pelo startup_arch4.sh no boot da VM.
#       Ver ARCHITECTURE.md: "NUNCA use docker cp da imagem golden"

FROM nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=America/Sao_Paulo
ENV PYTHONUNBUFFERED=1

# ═══════════════════════════════════════════════════════════════════════════
# LAYER 1: Dependências de sistema (apt) — raramente muda
# ═══════════════════════════════════════════════════════════════════════════
RUN apt-get update && apt-get install -y \
    software-properties-common \
    python3.10 \
    python3-pip \
    python3.10-dev \
    git \
    wget \
    curl \
    ffmpeg \
    libsndfile1 \
    libavcodec-dev \
    libsm6 \
    libxext6 \
    libgl2ps-dev \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/python3.10 /usr/bin/python \
    && pip3 install --no-cache-dir --upgrade pip \
    && pip3 install --no-cache-dir cmake cython

# ═══════════════════════════════════════════════════════════════════════════
# LAYER 2: PyTorch CUDA 12.1 — muda só com upgrade de CUDA/PyTorch
# ═══════════════════════════════════════════════════════════════════════════
RUN pip3 install --no-cache-dir \
    torch==2.5.1+cu121 \
    torchvision==0.20.1+cu121 \
    torchaudio==2.5.1+cu121 \
    --extra-index-url https://download.pytorch.org/whl/cu121

# ═══════════════════════════════════════════════════════════════════════════
# LAYER 3: ML Core — muda a cada upgrade de diffusers/transformers
# ═══════════════════════════════════════════════════════════════════════════
RUN pip3 install --no-cache-dir \
    numpy==1.26.4 \
    diffusers==0.31.0 \
    transformers==4.46.1 \
    opencv-python-headless==4.10.0.84 \
    insightface==0.7.3 \
    facexlib==0.3.0 \
    onnxruntime-gpu==1.19.2 \
    omegaconf==2.3.0 \
    einops==0.8.0 \
    gfpgan==1.3.8 \
    scipy==1.13.1

# ═══════════════════════════════════════════════════════════════════════════
# LAYER 4: LatentSync Dependencies — muda ao adicionar features novas
# --no-build-isolation: lws precisa de numpy no build, mas pip cria
# um ambiente isolado vazio. Forçamos usar o numpy já instalado.
# ═══════════════════════════════════════════════════════════════════════════
RUN pip3 install --no-cache-dir --no-build-isolation \
    eva-decord==0.6.1 \
    accelerate==0.27.2 \
    kornia==0.7.3 \
    lws==1.2.0 \
    imageio==2.30.0 \
    more-itertools==9.0.0 \
    soundfile==0.12.1 \
    librosa==0.10.2 \
    --extra-index-url https://download.pytorch.org/whl/cu121 && \
    pip3 show -f eva-decord | head -30 && \
    python3 -c "import pkgutil; [print(f'PKG:{m.name}') for m in pkgutil.iter_modules() if 'decord' in m.name.lower()]"

# ═══════════════════════════════════════════════════════════════════════════
# LAYER 5: Servidor API — estável, mesma versão do api/requirements.txt
# ═══════════════════════════════════════════════════════════════════════════
RUN pip3 install --no-cache-dir \
    fastapi==0.115.0 \
    uvicorn==0.31.0 \
    python-multipart==0.0.12 \
    google-cloud-storage==2.18.2 \
    requests==2.32.3 \
    pydantic==2.7.4 \
    python-dotenv==1.0.1 \
    tqdm==4.66.5

# ═══════════════════════════════════════════════════════════════════════════
# LAYER 6: DeepCache (git) — muda se o repo upstream mudar
# ═══════════════════════════════════════════════════════════════════════════
RUN pip3 install --no-cache-dir \
    git+https://github.com/horseee/DeepCache.git@master

# ═══════════════════════════════════════════════════════════════════════════
# LAYER 7: Workspace (código Python NÃO vai na imagem)
# ═══════════════════════════════════════════════════════════════════════════
# O código (src/ + latentsync/) é obtido via git clone pelo startup_arch4.sh.
# A imagem contém APENAS dependências de sistema e pip (layers 1-6).
# Ver ARCHITECTURE.md: "NUNCA extraído da imagem golden"
ENV PYTHONPATH=/workspace/latentsync:/workspace/src
WORKDIR /workspace
RUN mkdir -p /workspace/outputs/temp /workspace/latentsync/assets \
    && chmod -R 777 /workspace

LABEL project="Lana"
LABEL tier="Industrial-V20"
LABEL version="2.10"
